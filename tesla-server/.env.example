# Server
SERVER_PORT=1255
GIN_MODE=release

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=teslaapp

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Tesla OAuth (China)
# Get your Client ID and Secret from https://developer.tesla.cn
TESLA_CLIENT_ID=your_tesla_client_id
TESLA_CLIENT_SECRET=your_tesla_client_secret
TESLA_REDIRECT_URI=https://your-domain.com/api/tesla/callback
TESLA_FRONTEND_CALLBACK_URL=https://your-domain.com/#/pages/callback/callback

# Vehicle Command Proxy (VCP)
# Leave empty to send commands directly via Fleet API (not recommended for China region)
# China region vehicle control commands (unlock, trunk, etc.) require VCP proxy
# tesla-http-proxy default: https://localhost:4443
TESLA_VCP_URL=https://127.0.0.1:4443

# Partner Domain (for pairing URL generation and Partner Account registration)
# Must match the domain registered in Tesla Developer Portal
TESLA_PARTNER_DOMAIN=your-domain.com

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=86400

# Tencent Map (optional)
TENCENT_MAP_KEY=your_tencent_map_key

# AI - Zhipu GLM (optional)
AI_API_KEY=
AI_MODEL=glm-4-flash
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
