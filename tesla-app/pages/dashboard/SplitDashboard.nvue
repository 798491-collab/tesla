const simDestLat = ref(0)
const simDestLng = ref(0)
const simDestName = ref('')
const showCustomDestInput = ref(false)
const customDestLat = ref('')
const customDestLng = ref('')
const customDestName = ref('')

// 预设目的地（上海地区真实地标）
const simDestinations = [
	{ name: '上海虹桥站', lat: 31.1944, lng: 121.3200 },
	{ name: '浦东国际机场', lat: 31.1443, lng: 121.8083 },
	{ name: '外滩', lat: 31.2400, lng: 121.4900 },
	{ name: '陆家嘴', lat: 31.2350, lng: 121.5015 },
	{ name: '迪士尼乐园', lat: 31.1434, lng: 121.6580 },
	{ name: '人民广场', lat: 31.2320, lng: 121.4730 },
]

const simHasDest = computed(() => !!(simDestLat.value && simDestLng.value))
const simDistToDest = computed(() => {
	if (!simHasDest.value) return '--'
	const d = haversineKm(simLat.value, simLng.value, simDestLat.value, simDestLng.value)
	return d < 1 ? Math.round(d * 1000) + 'm' : d.toFixed(1) + 'km'
})
const simEtaDisplay = computed(() => {
	if (!simHasDest.value || simCurrentSpeed.value < 1) return '--'
	const d = haversineKm(simLat.value, simLng.value, simDestLat.value, simDestLng.value)
	const mins = Math.round((d / simCurrentSpeed.value) * 60)
	if (mins < 60) return mins + '分钟'
	return Math.floor(mins / 60) + '时' + (mins % 60) + '分'
})

// 模拟导航步骤（非APP端降级用）
const simNavSteps = ref([])
const simCurrentNavStep = ref(0)
const simNavStepProgress = ref(0)

function haversineKm(lat1, lng1, lat2, lng2) {
	const R = 6371
	const dLat = (lat2 - lat1) * Math.PI / 180
	const dLng = (lng2 - lng1) * Math.PI / 180
	const a = Math.sin(dLat / 2) ** 2 + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLng / 2) ** 2
	return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a))
}

// 生成模拟导航步骤（非APP端降级用）
function generateSimNavSteps(startLat, startLng, endLat, endLng) {
	const totalDist = haversineKm(startLat, startLng, endLat, endLng)
	const steps = []
	const numSteps = Math.max(3, Math.min(8, Math.round(totalDist / 3)))
	const dLat = (endLat - startLat) / numSteps
	const dLng = (endLng - startLng) / numSteps
	const directions = ['请沿当前道路继续行驶', '前方左转', '前方右转', '稍向左转', '稍向右转', '直行通过路口', '进入主路']
	const roads = ['世纪大道', '延安高架路', '内环高架路', '沪闵高架路', '南北高架路', '中环路', '外环路', '龙东大道', '张杨路', '南京东路']

	for (let i = 0; i < numSteps; i++) {
		const dist = (totalDist / numSteps) * 1000
		steps.push({
			act_desc: i === 0 ? '出发' : i === numSteps - 1 ? '到达目的地' : directions[Math.floor(Math.random() * directions.length)],
			road_name: i === numSteps - 1 ? '目的地' : roads[Math.floor(Math.random() * roads.length)],
			distance: Math.round(dist * (0.8 + Math.random() * 0.4)),
			waypoint_lat: startLat + dLat * (i + 1),
			waypoint_lng: startLng + dLng * (i + 1),
		})
	}
	return steps
}

// 模拟数据注入到 vehicleDataStore（reactive 对象，直接赋值触发响应式更新）
function injectSimData() {
	const isDriving = simGear.value === 'D' || simGear.value === 'R'
	const soc = Math.round(simBattery.value)
	const rangeKm = Math.round(soc * 5.8 * 10) / 10
	const isCharging = simCharging.value
	const chargePower = isCharging ? simChargePower.value : 0
	const voltage = isCharging ? 380 : 0
	const ampere = isCharging ? Math.round(chargePower / 380 * 1000) / 10 : 0

	const newData = {
		...vehicleDataStore.data,
		// 行驶数据
		speed: Math.round(simCurrentSpeed.value * 10) / 10,
		gear: simGear.value,
		shift_state: simGear.value,
		power: isDriving ? Math.round(simCurrentSpeed.value * 0.15 * 10) / 10 : 0,
		pedal_position: simCurrentSpeed.value > 0 ? Math.min(1, simCurrentSpeed.value / simTargetSpeed.value) : 0,
		brake_pedal: 0,
		drive_rail: 'dual',
		cruise_set_speed: null,

		// 电池/充电
		soc,
		battery_level: soc,
		usable_soc: soc,
		range_km: rangeKm,
		energy_remaining: Math.round(soc * 0.75 * 10) / 10,
		battery_temp: isCharging ? 32 + Math.random() * 5 : 25 + Math.random() * 3,
		charging: isCharging,
		charging_state: isCharging ? 'Charging' : 'Idle',
		charge_state: isCharging ? 'Charging' : 'Idle',
		charge_power: chargePower,
		charger_power: chargePower,
		dc_charging_power: isCharging ? chargePower : 0,
		ac_charging_power: 0,
		voltage,
		charger_voltage: voltage,
		pack_voltage: isCharging ? 380 : 0,
		ampere,
		charge_amps: ampere,
		pack_current: isCharging ? ampere : 0,
		fast_charger_present: isCharging && soc < 80,
		supercharging: isCharging && soc < 80,
		charge_port_door_open: isCharging,
		charge_limit_soc: 80,
		minutes_to_full: isCharging ? Math.round((80 - soc) / (chargePower / 75) * 60) : 0,
		battery_heater_on: false,
		added_energy: 0,

		// GPS
		latitude: simLat.value,
		longitude: simLng.value,
		heading: Math.round(simHeading.value),
		gps_state: 3,

		// 温控
		inside_temp: Math.round((simInsideTemp.value + (Math.random() - 0.5) * 0.3) * 10) / 10,
		outside_temp: Math.round((simOutsideTemp.value + (Math.random() - 0.5) * 0.5) * 10) / 10,
		is_ac_on: true,
		hvac_power: true,
		hvac_ac_enabled: true,
		hvac_auto_mode: true,
		hvac_fan_speed: 3,
		driver_temp_setting: 22,
		passenger_temp_setting: 22,
		defrost_mode: false,
		steering_wheel_heater: false,
		climate_keeper_mode: false,

		// 车门/窗/锁
		locked: simLocked.value,
		door_fl: simDoors.value.fl,
		door_fr: simDoors.value.fr,
		door_rl: simDoors.value.rl,
		door_rr: simDoors.value.rr,
		door_open: simDoors.value.fl || simDoors.value.fr || simDoors.value.rl || simDoors.value.rr,
		trunk_open: simTrunkOpen.value,
		frunk_open: simFrunkOpen.value,
		fd_window: false,
		fp_window: false,
		rd_window: false,
		rp_window: false,
		windows_open: false,
		mirror_folded: false,
		sentry_mode: false,

		// 座椅加热
		seat_heater_left: 0,
		seat_heater_right: 0,
		seat_heater_rear_left: 0,
		seat_heater_rear_right: 0,
		seat_heater_rear_center: 0,

		// 里程
		odometer_km: simOdometer.value,

		// 灯光
		lights_high_beams: false,
		lights_hazards_active: false,
		lights_turn_signal: 'off',

		// 驾驶状态
		driving: isDriving,
		center_display_state: 1,

		// 轮胎
		tpms_pressure_fl: 2.9,
		tpms_pressure_fr: 2.9,
		tpms_pressure_rl: 2.8,
		tpms_pressure_rr: 2.8,
	}

	// 导航目的地
	if (simHasDest.value) {
		newData.destination_latitude = simDestLat.value
		newData.destination_longitude = simDestLng.value
		newData.destination_name = simDestName.value
		newData.miles_to_arrival = haversineKm(simLat.value, simLng.value, simDestLat.value, simDestLng.value) * 0.621371
		newData.minutes_to_arrival = simCurrentSpeed.value > 1 ? Math.round((haversineKm(simLat.value, simLng.value, simDestLat.value, simDestLng.value) / simCurrentSpeed.value) * 60) : 999
	} else {
		newData.destination_latitude = 0
		newData.destination_longitude = 0
		newData.destination_name = ''
	}

	// 直接赋值触发 reactive 响应式更新
	vehicleDataStore.data = newData
	vehicleDataStore.source = 'ble'
	vehicleDataStore.bleConnected = true
}

// 模拟器主循环
function simTick() {
	// 速度模拟
	if (simGear.value === 'D') {
		if (simCurrentSpeed.value < simTargetSpeed.value) {
			simCurrentSpeed.value = Math.min(simCurrentSpeed.value + 2 + Math.random() * 3, simTargetSpeed.value)
		} else if (simCurrentSpeed.value > simTargetSpeed.value) {
			simCurrentSpeed.value = Math.max(simCurrentSpeed.value - 3 - Math.random() * 2, simTargetSpeed.value)
		}
		simCurrentSpeed.value += (Math.random() - 0.5) * 1.5
		simCurrentSpeed.value = Math.max(0, simCurrentSpeed.value)
	} else if (simGear.value === 'R') {
		simCurrentSpeed.value = Math.min(simCurrentSpeed.value + 1, 10)
	} else {
		if (simCurrentSpeed.value > 0.5) {
			simCurrentSpeed.value = Math.max(0, simCurrentSpeed.value - 2 - Math.random() * 2)
		} else {
			simCurrentSpeed.value = 0
		}
	}

	// GPS 轨迹模拟
	if (simCurrentSpeed.value > 0.5) {
		const speedMs = simCurrentSpeed.value / 3.6
		const dt = 0.2
		const distM = speedMs * dt
		const dLat = (distM / 111000) * Math.cos(simHeading.value * Math.PI / 180)
		const dLng = (distM / (111000 * Math.cos(simLat.value * Math.PI / 180))) * Math.sin(simHeading.value * Math.PI / 180)
		simLat.value = Math.round((simLat.value + dLat) * 100000) / 100000
		simLng.value = Math.round((simLng.value + dLng) * 100000) / 100000
		simOdometer.value += distM / 1000

		// 导航模式下，朝目的地方向微调航向
		if (simHasDest.value) {
			const targetBearing = bearingTo(simLat.value, simLng.value, simDestLat.value, simDestLng.value)
			let diff = targetBearing - simHeading.value
			while (diff > 180) diff -= 360
			while (diff < -180) diff += 360
			simHeading.value += diff * 0.03 + (Math.random() - 0.5) * 2
			if (simHeading.value < 0) simHeading.value += 360
			if (simHeading.value >= 360) simHeading.value -= 360
		} else {
			simHeading.value += (Math.random() - 0.5) * 3
			if (simHeading.value < 0) simHeading.value += 360
			if (simHeading.value >= 360) simHeading.value -= 360
		}

		// 更新原生地图车辆位置标记
		if (mapLoaded) {
			naviUpdateVehicleMarker(simLat.value, simLng.value, Math.round(simHeading.value))
		}
	}

	// 电池消耗/充电
	if (simCharging.value) {
		simBattery.value = Math.min(100, simBattery.value + 0.02 * (simChargePower.value / 50))
	} else if (simCurrentSpeed.value > 1) {
		const consumption = (simCurrentSpeed.value / 3.6 * 0.2) * 0.15 / 100
		const batteryCapacity = 75
		simBattery.value = Math.max(0, simBattery.value - (consumption / batteryCapacity) * 100)
	}

	// 导航到达检测
	if (simHasDest.value && simCurrentSpeed.value > 0.5) {
		const dist = haversineKm(simLat.value, simLng.value, simDestLat.value, simDestLng.value)
		if (dist < 0.05) {
			uni.showToast({ title: '已到达目的地: ' + simDestName.value, icon: 'success' })
			clearSimDest()
		}
	}

	// #ifndef APP-PLUS
	// 非APP端：用模拟导航步骤驱动导航浮层显示
	if (simHasDest.value && simNavSteps.value.length > 0) {
		simNavStepProgress.value += 0.005
		if (simNavStepProgress.value >= 1) {
			simNavStepProgress.value = 0
			simCurrentNavStep.value++
			if (simCurrentNavStep.value >= simNavSteps.value.length) {
				simCurrentNavStep.value = simNavSteps.value.length - 1
			}
		}
		const remaining = simNavSteps.value.slice(simCurrentNavStep.value)
		if (remaining.length > 0) {
			navSteps.value = remaining.map((s, i) => ({
				...s,
				distance: i === 0 ? Math.round(s.distance * (1 - simNavStepProgress.value)) : s.distance,
			}))
		}
		navigationActive.value = true
	}
	// #endif

	injectSimData()
}

function bearingTo(lat1, lng1, lat2, lng2) {
	const dLng = (lng2 - lng1) * Math.PI / 180
	const la1 = lat1 * Math.PI / 180
	const la2 = lat2 * Math.PI / 180
	const y = Math.sin(dLng) * Math.cos(la2)
	const x = Math.cos(la1) * Math.sin(la2) - Math.sin(la1) * Math.cos(la2) * Math.cos(dLng)
	let bearing = Math.atan2(y, x) * 180 / Math.PI
	return (bearing + 360) % 360
}

function toggleSim() {
	if (simActive.value) {
		stopSim()
	} else {
		startSim()
	}
}

function startSim() {
	if (simTimer) return
	simActive.value = true
	if (!simLat.value || (simLat.value === 31.2304 && simLng.value === 121.4737)) {
		simLat.value = 31.2304
		simLng.value = 121.4737
		simHeading.value = Math.random() * 360
	}
	simTimer = setInterval(simTick, 200)
	injectSimData()
	// 在原生地图上显示模拟车辆位置
	if (mapLoaded && mapSettings.value.mapMode.showVehicleMarker) {
		naviShowVehicleMarker(simLat.value, simLng.value, Math.round(simHeading.value))
	}
}

function stopSim() {
	if (simTimer) {
		clearInterval(simTimer)
		simTimer = null
	}
	simActive.value = false
	simCurrentSpeed.value = 0
	// 停止导航
	if (navigationActive.value) {
		navigationActive.value = false
		naviStopNavi()
	}
	// 恢复数据源，清理模拟器注入的数据
	vehicleDataStore.bleConnected = false
	vehicleDataStore.source = 'ws'
	// 清理 state/realtime 层，让 WS 重新填充
	vehicleDataStore.realtime = {}
	vehicleDataStore.realtimeUpdatedAt = 0
	vehicleDataStore.realtimeSource = null
	// 重新从 WS 获取初始状态
	if (vehicleDataStore.vin) {
		initVehicleData(vehicleDataStore.vin)
	}
}

function setSimGear(g) {
	simGear.value = g
	if (g === 'P' || g === 'N') {
		simTargetSpeed.value = 0
	} else if (g === 'D' && simTargetSpeed.value === 0) {
		simTargetSpeed.value = 60
	} else if (g === 'R') {
		simTargetSpeed.value = 5
	}
	if (g !== 'P') {
		simCharging.value = false
	}
}

function toggleSimCharging() {
	simCharging.value = !simCharging.value
	if (simCharging.value) {
		simGear.value = 'P'
		simTargetSpeed.value = 0
		simCurrentSpeed.value = 0
		simChargePower.value = Math.round(30 + Math.random() * 90)
	}
}

// 启动模拟导航（走原生插件，simulator:true 启动完整导航模拟）
function startSimNavi() {
	if (!simHasDest.value || !mapLoaded) return

	// #ifdef APP-PLUS
	// APP端：走原生导航插件，使用 simulator:true 让 SDK 自动模拟沿路线行驶
	console.log('[SplitDashboard] 模拟导航: 原生插件导航到', simDestName.value, simDestLat.value, simDestLng.value)
	// 先注入目的地数据，让 startAutoNavi 能读到
	injectSimData()
	// 延迟触发原生导航（等待数据注入生效）
	setTimeout(() => {
		if (!navigationActive.value) {
			startAutoNavi(true) // simulator = true
		}
	}, 300)
	// #endif

	// #ifndef APP-PLUS
	// 非APP端：用模拟导航步骤
	simNavSteps.value = generateSimNavSteps(simLat.value, simLng.value, simDestLat.value, simDestLng.value)
	simCurrentNavStep.value = 0
	simNavStepProgress.value = 0
	navigationActive.value = true
	// #endif
}

function selectSimDest(idx) {
	if (simSelectedDest.value === idx) {
		clearSimDest()
		return
	}
	simSelectedDest.value = idx
	const dest = simDestinations[idx]
	simDestLat.value = dest.lat
	simDestLng.value = dest.lng
	simDestName.value = dest.name
	showCustomDestInput.value = false
	// 自动切到D档
	if (simGear.value === 'P') {
		setSimGear('D')
	}
	// 启动模拟器（如果还没启动）
	if (!simActive.value) {
		startSim()
	}
	// 启动导航
	setTimeout(() => startSimNavi(), 200)
}

function applyCustomDest() {
	const lat = parseFloat(customDestLat.value)
	const lng = parseFloat(customDestLng.value)
	if (isNaN(lat) || isNaN(lng) || lat < -90 || lat > 90 || lng < -180 || lng > 180) {
		uni.showToast({ title: '坐标格式错误', icon: 'none' })
		return
	}
	simSelectedDest.value = -1
	simDestLat.value = lat
	simDestLng.value = lng
	simDestName.value = customDestName.value || '自定义目的地'
	if (simGear.value === 'P') {
		setSimGear('D')
	}
	if (!simActive.value) {
		startSim()
	}
	showCustomDestInput.value = false
	// 启动导航
	setTimeout(() => startSimNavi(), 200)
}

function clearSimDest() {
	simDestLat.value = 0
	simDestLng.value = 0
	simDestName.value = ''
	simSelectedDest.value = -1
	simNavSteps.value = []
	simCurrentNavStep.value = 0
	simNavStepProgress.value = 0
	navigationActive.value = false
	navSteps.value = []
	// 停止原生导航
	naviStopNavi()
	degradeToMap()
	// 清除注入数据中的目的地
	if (simActive.value) {
		injectSimData()
	}
}

function applySimScene(scene) {
	switch (scene) {
		case 'parked':
			simGear.value = 'P'
			simTargetSpeed.value = 0
			simCurrentSpeed.value = 0
			simCharging.value = false
			simLocked.value = true
			simDoors.value = { fl: false, fr: false, rl: false, rr: false }
			simTrunkOpen.value = false
			simFrunkOpen.value = false
			break
		case 'city':
			simGear.value = 'D'
			simTargetSpeed.value = 40 + Math.round(Math.random() * 30)
			simCharging.value = false
			simLocked.value = true
			simDoors.value = { fl: false, fr: false, rl: false, rr: false }
			break
		case 'highway':
			simGear.value = 'D'
			simTargetSpeed.value = 100 + Math.round(Math.random() * 30)
			simCharging.value = false
			simLocked.value = true
			simDoors.value = { fl: false, fr: false, rl: false, rr: false }
			break
		case 'charging':
			simGear.value = 'P'
			simTargetSpeed.value = 0
			simCurrentSpeed.value = 0
			simCharging.value = true
			simChargePower.value = Math.round(50 + Math.random() * 70)
			simLocked.value = true
			simDoors.value = { fl: false, fr: false, rl: false, rr: false }
			simTrunkOpen.value = false
			simFrunkOpen.value = false
			break
	}
	if (!simActive.value) {
		startSim()
	}
}

// 页面卸载时清理模拟器 - 已合并到上方 onUnmounted

// ===== 车辆模拟引擎 END =====

// 切换车辆时重新初始化数据
watch(() => currentVehicle.value, (newVal) => {
	destroyVehicleData()
	if (newVal) {
		initVehicleData(newVal.vin)
	}
})
</script>

