const simTargetSpeed = ref(0)
const simCurrentSpeed = ref(0)
const simBattery = ref(78)
const simCharging = ref(false)
const simChargePower = ref(50)
const simInsideTemp = ref(22.5)
const simOutsideTemp = ref(18.0)
const simLat = ref(31.2304)
const simLng = ref(121.4737)
const simHeading = ref(0)
const simOdometer = ref(12345.6)

// 车门/窗/锁
