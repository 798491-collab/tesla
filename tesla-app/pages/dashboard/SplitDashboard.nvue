}

/* 行驶数据面板 */
.drive-data-board {
	padding: 16px 20px;
	background-color: #1C1C1E;
	margin: 0 15px 10px 15px;
	border-radius: 14px;
}
.main-stats-row {
	flex-direction: row;
	justify-content: space-around;
	align-items: flex-end;
}
.stat-block {
	align-items: center;
}
.speed-value {
	font-size: 48px;
	color: #FFFFFF;
	font-weight: bold;
	font-family: monospace;
}
.gear-value {
	font-size: 38px;
	color: #3875F6;
	font-weight: bold;
}
.stat-unit {
	color: #8E8E93;
	font-size: 11px;
	margin-top: 2px;
}

.sub-stats-row {
	flex-direction: row;
	justify-content: space-between;
	margin-top: 12px;
	padding-top: 12px;
	border-top-width: 1px;
	border-top-color: #2C2C2E;
}
.sub-stat-item {
	flex-direction: row;
	align-items: center;
}
.battery-dot {
	width: 8px;
	height: 8px;
	border-radius: 4px;
	margin-right: 6px;
}
.sub-stat-text {
	color: #AEAEB2;
	font-size: 13px;
}

/* 迷你音乐栏 */
.mini-music-bar {
	height: 32px; 
	background-color: #121212;
	justify-content: center;
	padding: 0 15px;
	position: relative;
}
.music-content {
	flex-direction: row;
	align-items: center;
}
.music-title-text {
	color: #8E8E93;
